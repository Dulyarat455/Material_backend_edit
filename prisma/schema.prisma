// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}


model User {
    id Int @id() @default(autoincrement())
    rfId String
    empNo String
    name String
    password String
    role String?
    status String @default("use")
    MapSectionGroupUser MapSectionGroupUser[]
    TransactionStore TransactionStore[]
    TransactionStoreHistory TransactionStoreHistory[]
    Job Job[]
    StockOut StockOut[]
    RemoveUser RemoveUser[]
}



model Group{
    id Int @id() @default(autoincrement())
    name String
    status String @default("use")
    MapSectionGroupUser MapSectionGroupUser[]
}


model Section{
  id Int @id() @default(autoincrement())
  name String
  status String @default("use")
  MapSectionGroupUser MapSectionGroupUser[]
}


model MapSectionGroupUser{
  id Int @id() @default(autoincrement())
  userId Int 
  groupId Int
  sectionId Int
  status String @default("use")
  Section Section @relation(fields: [sectionId], references: [id])
  Group Group @relation(fields: [groupId], references: [id])
  User User @relation(fields: [userId], references: [id])
}



model Area{
  id Int @id() @default(autoincrement())
  name String
  status String @default("use")
  MapLineArea MapLineArea[]
  TimeStateIncoming TimeStateIncoming[]
  Job Job[]
}


model Line{
  id Int @id() @default(autoincrement())
  name String 
  status String @default("use")
  MapLineArea MapLineArea[]
}


model MapLineArea{
  id Int @id() @default(autoincrement())
  areaId Int
  lineId Int 
  status String @default("use")
  Line Line @relation(fields: [lineId], references: [id])
  Area Area @relation(fields: [areaId], references: [id])
}



model Store{
  id Int @id() @default(autoincrement())
  name String
  status String @default("use")
  TransactionStore TransactionStore[]
  TransactionStoreHistory TransactionStoreHistory[]
  MapStoreLayOut MapStoreLayOut[]
}


model Incoming{
  id Int @id() @default(autoincrement())
  jobNo String
  yearMonth String
  recivedDate String
  inspector String
  unloadBy String
  invoiceOne String
  taxLnvNo String
  materialNo String
  unitPrice String
  qtyOfPalletPack String
  coil Int
  qtyKgsPcs Float
  unit String
  kgsCoil String
  odCoil String
  remark String
  millSheet String
  itemName String
  itemSpec String
  lotNo String
  packing String
  rosh String
  result String
  supplier String
  amount String
  notControl String?
  reInspectionDate DateTime?
  status String @default("use")
  TimeStateIncoming TimeStateIncoming[]
  TransactionStore TransactionStore[]
  TransactionStoreHistory TransactionStoreHistory[]
  StockOut StockOut[]
  IncomingLoc IncomingLoc[]
}



model TimeStateIncoming {
  id Int @id() @default(autoincrement())
  incomingId Int
  areaId Int 
  state String
  timeStmp DateTime @default(now())
  status String @default("use")
  Incoming Incoming @relation(fields: [incomingId], references: [id])
  Area Area @relation(fields: [areaId], references: [id])
}


model TransactionStore {
  id Int @id() @default(autoincrement())
  storeId Int
  incomingId Int
  timeStmp DateTime @default(now())
  userId Int
  stockNote String?
  status String @default("use")
  Store Store @relation(fields: [storeId], references: [id])
  Incoming Incoming @relation(fields: [incomingId], references: [id])
  User User @relation(fields: [userId], references: [id])
}



model TransactionStoreHistory {
  id Int @id() @default(autoincrement())
  storeId Int
  incomingId Int
  timeStmp DateTime @default(now())
  userId Int
  stockNote String?
  type String?
  coil Int?
  qty Float?
  status String @default("use")
  Store Store @relation(fields: [storeId], references: [id])
  Incoming Incoming @relation(fields: [incomingId], references: [id])
  User User @relation(fields: [userId], references: [id])
}



model Material {
  id Int @id() @default(autoincrement())
  materialNo String
  materialName String
  materialSpec String
  accountCode String?
  timeStamp DateTime @default(now())
  lineNo String?
  status String @default("use")
  Job Job[]
}




model MapStoreLayOut {
  id Int @id() @default(autoincrement())
  storeId Int
  zone String
  row String
  status String @default("use")
  Store Store @relation(fields: [storeId], references: [id]) 
}




model Job {
  id Int @id() @default(autoincrement())
  jobNo String
  IncomingId Int?
  areaId Int
  groupId Int?
  requestByUserId Int
  requestTime  DateTime @default(now())
  inchargeByUserId Int?
  inchargeTime DateTime?
  type String
  materialId Int
  state String
  remark String?
  remarkMC String?
  accountCode String?
  priority String
  status String @default("use")
  Area Area @relation(fields: [areaId], references: [id])
  RequestUser User @relation(fields: [requestByUserId], references: [id])
  Material Material @relation(fields: [materialId], references: [id])
  IncomingLoc IncomingLoc[]
}


model StockOut {
  id Int @id() @default(autoincrement())
  incomingId Int
  type String?
  inchargeByUserId Int
  remark String?
  coil Int?
  qty Float?
  timeStmp DateTime @default(now())
  status String @default("use")
  Incoming Incoming @relation(fields: [incomingId], references: [id])
  User User @relation(fields: [inchargeByUserId], references: [id])
}




model IncomingLoc {
  id Int @id() @default(autoincrement())
  incomingId Int 
  coil Int
  qty Float 
  jobId Int
  timeStmp DateTime @default(now())
  status String @default("use")
  Incoming Incoming @relation(fields: [incomingId], references: [id])
  Job Job @relation(fields: [jobId], references: [id])
}



model RemoveUser {
  id Int @id() @default(autoincrement())
  userId Int
  timeStmp DateTime @default(now())
  status String @default("use")
  User User @relation(fields: [userId], references: [id])
}



model SyncTimeStmp {
  id Int @id() @default(autoincrement())
  remark String
  userId Int?
  timeStmp DateTime @default(now())
  status String @default("use")
}


model LogNotControl {
  id Int @id() @default(autoincrement())
  incomingId Int?
  historyId Int?
  notControl String
  status String @default("use")
  timeStmp DateTime @default(now())
}


model IncomingEditReturn {
  id Int @id() @default(autoincrement())
  incomingId Int
  timeStmp DateTime
  status String @default("use")
}


model LogEditLastReturn {
  id Int @id() @default(autoincrement())
  historyId Int
  lastReturn String
  lastReturnId Int 
  status String @default("use")
}


model LogEditInSpection {
  id Int @id() @default(autoincrement())
  historyId Int
  incomingId Int
  inSpection String 
  timeStmp DateTime @default(now())
  status String @default("use")
}


model RecordInventory {
  id Int @id() @default(autoincrement())
  incomingId Int
  storeId Int
  coil Int
  qty Float
  totalPrice Float
  lineNo String
  timeStmp DateTime 
  status String @default("use")
}



model TargetGraph {
  id Int @id() @default(autoincrement())
  graph String
  target Float
  status String @default("use")
}







